        "jsCode": "// Verify the HMAC-SHA256 signature Solux sends on every delivery.\n// Set WHSEC to your endpoint's signing secret (whsec_...), shown once at\n// creation in Settings → Integrations → Outbound webhooks.\nconst crypto = require('crypto');\nconst WHSEC = 'whsec_REPLACE_WITH_YOUR_SIGNING_SECRET';\n\nconst item = $input.first();\nconst headers = item.json.headers || {};\nconst raw = JSON.stringify(item.json.body);\nconst expected = 'sha256=' + crypto.createHmac('sha256', WHSEC).update(raw).digest('hex');\nconst got = headers['x-solux-signature'];\nif (expected !== got) {\n  throw new Error('Invalid Solux signature — rejecting delivery');\n}\nreturn [{ json: item.json.body }];"
      },
