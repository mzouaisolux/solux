      "parameters": {
        "jsCode": "// Normalize a WhatsApp Business / Zalo OA inbound payload into the Solux\n// inbound-API shape. Adjust field paths to your provider's webhook format.\nconst b = ($input.first().json.body) || {};\nlet phone = '', text = '', channel = 'whatsapp';\nconst wa = b?.entry?.[0]?.changes?.[0]?.value?.messages?.[0];\nif (wa) { channel = 'whatsapp'; phone = wa.from; text = wa.text?.body || ''; }\nelse if (b?.sender?.id) { channel = 'zalo'; phone = b.sender.id; text = b.message?.text || ''; }\nreturn [{ json: { phone, channel, direction: 'inbound', summary: text } }];"
      },
      "id": "b1a1c001-0000-4000-8000-000000000031",
