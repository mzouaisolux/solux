# dependencies
node_modules
node_modules */

# next build (+ iCloud conflict copies like ".next 2", ".next 3")
.next
.next */
.next*

# typescript incremental build cache (regenerated on every tsc run)
*.tsbuildinfo

# pdf.js worker copied out of node_modules by scripts/copy-pdf-worker.mjs
# (postinstall / predev / prebuild). Generated, never committed — a committed
# copy would silently drift from the installed pdfjs-dist version.
/public/pdf.worker.min.mjs

# env / secrets
.env.local
.env*.local
.env.e2e
.env*.bak
*.bak

# E2E harness artifacts (sessions, run reports, traces)
e2e/.auth
e2e/.runs

# sales-analytics import data + local staging (real customer financials / binaries — never commit)
/data/

# scratch: temp audit scripts, design references, office lock files
*.tmp.ts
*.tmp.mjs
.design-ref/
~$*

# misc
.DS_Store
*.log
