    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "read-excel-file": "^9.0.6",
    "unpdf": "^1.6.2",
    "write-excel-file": "^4.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  }
